{
  "name": "roku-perfetto",
  "version": "1.0.2",
  "description": "Library for Roku Perfetto tracing — ECP control, WebSocket recording, trace analysis with PerfettoSQL, and AI-friendly performance reports",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "bin": {
    "roku-perfetto": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "roku",
    "perfetto",
    "tracing",
    "performance",
    "profiling",
    "brightscript",
    "scenegraph",
    "ecp"
  ],
  "author": "Juan Carlos Joya Carvajal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jack1590/roku-perfetto.git"
  },
  "bugs": {
    "url": "https://github.com/jack1590/roku-perfetto/issues"
  },
  "homepage": "https://github.com/jack1590/roku-perfetto#readme",
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-xml-parser": "^4.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^6.0.0"
  }
}
